rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() { return request.auth != null; }
    function isNotFrozen() {
      let user = getUserSafe(request.auth.uid);
      return user == null || user.get('isFrozen', false) == false;
    }

    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function getUserSafe(userId) {
      let path = /databases/$(database)/documents/users/$(userId);
      return exists(path) ? get(path).data : null;
    }
    
    function isBootstrapAdmin() {
      return isSignedIn() && 
             request.auth.token.email.lower() == 'scottmoreau82@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    function getRole() {
      let user = getUserSafe(request.auth.uid);
      return user != null ? user.get('role', 'none').lower() : 'none';
    }

    function isAnyAdmin() {
      let user = getUserSafe(request.auth.uid);
      return isBootstrapAdmin() || (user != null && user.get('isFrozen', false) == false && (user.get('role', 'none').lower() in ['gm', 'admin', 'dealer_owner'] || user.get('isAdmin', false) == true));
    }

    function isAnyManager() {
      return isAnyAdmin() || (getRole() in ['manager', 'dealer_owner', 'gm']);
    }

    function isOrgMember(orgId) {
      let isAdmin = isBootstrapAdmin();
      let user = getUserSafe(request.auth.uid);
      let isPersonal = orgId.lower().startsWith('personal-');
      
      return isAdmin || (
        isSignedIn() && user != null && (
          // Access assigned org if it's personal OR user is not frozen
          (user.orgId == orgId && (isPersonal || user.get('isFrozen', false) == false)) ||
          // Always allow users to access their own personal workspace by checking ownerId
          (isPersonal && exists(/databases/$(database)/documents/organizations/$(orgId)) && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid)
        )
      );
    }

    // --- VALIDATION HELPERS ---

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.get('subscriptionTier', 'free').lower() in ['free', 'pro', 'organization', 'trial', 'premium', 'enterprise'];
    }

    function checkInvite(data) {
      let inviteId = data.get('inviteId', 'none');
      let inviteToken = data.get('inviteToken', 'none');
      let invite = get(/databases/$(database)/documents/invites/$(inviteId)).data;
      return invite != null && 
             invite.token == inviteToken && 
             invite.email.lower() == data.email.lower() &&
             invite.role.lower() == data.role.lower() &&
             invite.orgId == data.orgId &&
             invite.status == 'pending';
    }

    function isValidInvite(data) {
      return data.email is string &&
             data.role.lower() in ['manager', 'gm'] &&
             data.orgId is string &&
             data.token is string &&
             data.status in ['pending', 'accepted', 'expired', 'cancelled'] &&
             (data.expiresAt is number || data.expiresAt is timestamp) &&
             (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidDeal(data) {
      return data.customerName is string && 
             data.userId is string && 
             data.orgId is string &&
             data.status is string;
    }

    function isValidNote(data) {
      return data.text is string && 
             data.userId == request.auth.uid &&
             data.orgId is string;
    }

    function isValidGoal(data) {
      return data.userId == request.auth.uid &&
             data.unitGoal is number && 
             data.month is string;
    }

    function isValidDealerDeal(data) {
      return data.orgId is string &&
             data.createdByUserId == request.auth.uid &&
             data.date is string &&
             data.customerName is string &&
             data.dealNumber is string &&
             data.newOrUsed in ['N', 'U'] &&
             data.frontGross is number &&
             data.backGross is number &&
             (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidSpiff(data, isCreate) {
      return data.userId == request.auth.uid &&
             data.orgId is string &&
             data.amount is number &&
             data.month is string &&
             data.date is string &&
             (isCreate ? data.createdAt is timestamp : true) &&
             data.updatedAt is timestamp;
    }

    function isValidFeedback(data) {
      return data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 7000 &&
             data.type in ['bug', 'feature'] &&
             data.status in ['New', 'Reviewed', 'In Progress', 'Fixed', 'Closed', 'Rejected', 'Planned'] &&
             (data.get('screenshotUrl', '') is string) &&
             (data.get('attachmentPath', '') is string) &&
             (data.get('attachmentFileName', '') is string) &&
             (data.get('attachmentContentType', '') is string) &&
             (data.get('attachmentSize', 0) is number) &&
             (data.createdAt is number || data.createdAt is timestamp) &&
             (data.updatedAt is number || data.updatedAt is timestamp);
    }

    function isValidAnalyticsEvent(data) {
      return data.visitorId is string &&
             data.sessionId is string &&
             data.type is string &&
             data.timestamp is number;
    }

    function isValidAnalyticsSession(data) {
      return data.visitorId is string &&
             (data.get('userId', '') is string) &&
             data.startTime is number &&
             data.clickCount is number &&
             data.pagesViewed is list &&
             data.deviceInfo is map;
    }

    function isValidAnalyticsDailyAggregate(data) {
      return data.date is string &&
             data.timestamp is number &&
             (data.get('visits', 0) is number) &&
             (data.get('signups', 0) is number) &&
             (data.get('pageViews', 0) is number) &&
             (data.get('clicks', 0) is number) &&
             (data.get('activeSessions', 0) is number);
    }

    function isValidOrganization(data) {
      return data.get('name', 'Personal Workspace') is string &&
             data.get('ownerId', '') is string &&
             data.get('subscriptionTier', 'free').lower() in ['free', 'pro', 'organization', 'trial', 'premium', 'enterprise'] &&
             (data.get('status', 'active') in ['active', 'trial', 'suspended']);
    }

    function isValidJoinCodeRedemption(existing, incoming) {
      let isIncrement = incoming.usedCount == existing.usedCount + 1;
      let addsSelf = incoming.usedBy.size() == existing.usedBy.size() + 1 && incoming.usedBy.hasAll(existing.usedBy) && (request.auth.uid in incoming.usedBy);
      let notExpired = (existing.expiresAt is number ? existing.expiresAt : existing.expiresAt.toMillis()) > request.time.toMillis();
      let notAlreadyIn = !(request.auth.uid in existing.usedBy);
      let statusValid = (incoming.usedCount >= existing.maxUses) ? (incoming.status == 'used') : (incoming.status == 'active');
      
      // Domain validation
      let hasDomain = existing.get('dealerDomain', '') != '';
      let domainMatches = !hasDomain || (request.auth.token.get('email', '').lower().split('@')[1] == existing.dealerDomain.lower());

      return existing.status == 'active' && 
             notExpired && 
             notAlreadyIn && 
             isIncrement && 
             addsSelf && 
             statusValid &&
             domainMatches &&
             incoming.diff(existing).affectedKeys().hasOnly(['usedCount', 'usedBy', 'status']);
    }

    // --- COLLECTION RULES ---

    // Analytics Collections (Admin Only for Reading, User sessions for Writing)
    match /analyticsEvents/{eventId} {
      allow read: if isAnyAdmin();
      allow create: if isValidAnalyticsEvent(incoming());
      allow update, delete: if false;
    }

    match /analyticsSessions/{sessionId} {
      allow read: if isAnyAdmin();
      allow get: if true; // Knowledge of session ID serves as primary key
      allow create: if isValidAnalyticsSession(incoming());
      allow update: if isValidAnalyticsSession(incoming()) || isAnyAdmin();
      allow delete: if false;
    }

    match /analyticsDailyAggregates/{dateId} {
      allow read: if isAnyAdmin();
      allow create, update: if isValidAnalyticsDailyAggregate(incoming());
      allow delete: if false;
    }

    // Feedback Collection
    match /feedbackReports/{reportId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAnyAdmin());
      allow list: if isAnyAdmin();
      allow create: if isSignedIn() && isValidFeedback(incoming());
      allow update, delete: if isAnyAdmin();
    }

    // Invites Collection
    match /invites/{inviteId} {
      // Anyone signed in can read an invite if they have the ID (token check)
      allow get: if isSignedIn();
      // Only admins/GMs can list or create invites
      allow list: if isAnyAdmin();
      allow create: if isAnyAdmin() && isValidInvite(incoming());
      // Users can update status when accepting
      allow update: if isSignedIn() && (
        isAnyAdmin() || 
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'acceptedAt']) && incoming().status == 'accepted')
      );
      allow delete: if isAnyAdmin();
    }

    // User Collection
    match /users/{userId} {
      function isTargetOwner() {
        return existing().get('role', '').lower() == 'dealer_owner';
      }

      // isOwner is primary gate. Managers can see profiles within their org.
      allow get: if isOwner(userId) || isBootstrapAdmin() || (isSignedIn() && isAnyManager() && isOrgMember(getUserSafe(userId).get('orgId', 'none')));
      allow list: if isBootstrapAdmin() || (isSignedIn() && (isAnyManager() || isAnyAdmin()) && resource.data.get('orgId', 'none') == getUserSafe(request.auth.uid).get('orgId', 'other')); 
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().get('isAdmin', false) == false && (
        (incoming().get('role', '').lower() == 'sales') || 
        (incoming().get('role', '').lower() in ['manager', 'gm'] && checkInvite(incoming()))
      );
      
      allow update: if isBootstrapAdmin() || (isOwner(userId) && (
        // Standard profile updates
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'dashboardPreference', 'updatedAt', 'preferences', 'dealershipId', 'themePreference', 'suspensionAcknowledgedAt', 'customTheme', 'trialEndsAt']) ||
        // Joining an organization via join code/invite (transitioning from personal or none)
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'dashboardPreference', 'updatedAt', 'preferences', 'dealershipId', 'orgId', 'role', 'department', 'themePreference', 'suspensionAcknowledgedAt']) &&
         existing().role in ['sales', 'none', ''] &&
         incoming().role in ['manager', 'sales'] &&
         incoming().get('isAdmin', false) == false &&
         (existing().orgId == null || existing().orgId.lower().startsWith('personal-')))
      )) || (
        isAnyManager() && (isBootstrapAdmin() || isOrgMember(existing().get('orgId', 'none'))) &&
        // Protect owners from being frozen/deleted by non-founders/non-bootstrap/non-owner
        (!isTargetOwner() || getRole() == 'dealer_owner') &&
        incoming().diff(existing()).affectedKeys().hasOnly(['role', 'dealershipId', 'updatedAt', 'isAdmin', 'subscriptionTier', 'isFrozen', 'isDeleted', 'orgId', 'department'])
      );

      allow delete: if isBootstrapAdmin() || (
        isSignedIn() && isAnyManager() && isOrgMember(existing().get('orgId', 'none')) &&
        (!isTargetOwner() || getRole() == 'dealer_owner')
      );
      
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId) || isBootstrapAdmin();
      }
    }

    // Organization Collection
    match /organizations/{orgId} {
      allow get: if isSignedIn() && (isOrgMember(orgId) || isBootstrapAdmin() || (resource != null && resource.data.ownerId == request.auth.uid));
      allow list: if isSignedIn() && isBootstrapAdmin();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (
        isBootstrapAdmin() ||
        (resource != null && resource.data.ownerId == request.auth.uid) ||
        (isOrgMember(orgId) && isAnyManager())
      ) && isValidOrganization(incoming());

      match /activity/{eventId} {
        allow get, list: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow delete: if isOrgMember(orgId) && (isAnyAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      }

      match /deals/{dealId} {
        allow get, list: if isOrgMember(orgId) && (isAnyManager() || (resource != null && resource.data.userId == request.auth.uid));
        allow create: if isOrgMember(orgId) && isValidDeal(incoming());
        allow update: if isOrgMember(orgId) && (isAnyManager() || (resource != null && resource.data.userId == request.auth.uid));
        allow delete: if isOrgMember(orgId) && (isAnyManager() || (resource != null && resource.data.userId == request.auth.uid));
      }

      match /dealerships/{dsId} {
        allow read: if isOrgMember(orgId);
        allow write: if isAnyAdmin();
      }

      match /notes/{noteId} {
        allow get, list: if isOrgMember(orgId) && (resource == null || resource.data.userId == request.auth.uid);
        allow create: if isOrgMember(orgId) && isValidNote(incoming());
        allow update, delete: if isOrgMember(orgId) && existing().userId == request.auth.uid;
      }

      match /competitions/{compId} {
        allow get, list: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && isAnyManager();
      }

      match /monthlySpiffs/{spiffId} {
        allow get, list: if isOrgMember(orgId) && (isAnyManager() || (resource != null && resource.data.userId == request.auth.uid));
        allow create: if isOrgMember(orgId) && isValidId(spiffId) && isValidSpiff(incoming(), true);
        allow update: if isOrgMember(orgId) && (isAnyManager() || (resource != null && resource.data.userId == request.auth.uid)) && isValidSpiff(incoming(), false);
        allow delete: if isOrgMember(orgId) && (isAnyManager() || (resource != null && resource.data.userId == request.auth.uid));
      }

      match /dealerDeals/{dealId} {
        allow get, list: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId) && isValidDealerDeal(incoming());
        allow update: if isOrgMember(orgId) && (isAnyManager() || (resource != null && resource.data.createdByUserId == request.auth.uid));
        allow delete: if isOrgMember(orgId) && (isAnyManager() || (resource != null && resource.data.createdByUserId == request.auth.uid));
      }

      match /users/{userId}/payPlans/{planId} {
        allow read, write: if (isOrgMember(orgId) && isOwner(userId)) || isBootstrapAdmin();
      }

      // Dealer tier: org-level pay plan templates.
      // Read: any org member (salespeople need it — the resolver reads the template
      //   to compute their effective plan, and they get a read-only view of it).
      // Write: admins/owner only (managers don't manage templates at launch).
      match /payPlanTemplates/{templateId} {
        allow get, list: if isOrgMember(orgId) || isBootstrapAdmin();
        allow create, update, delete: if (isOrgMember(orgId) && isAnyAdmin()) || isBootstrapAdmin();
      }
    }

    match /goals/{goalId} {
      allow get, list: if isSignedIn() && (resource == null || isOwner(resource.data.userId) || isOrgMember(resource.data.orgId));
      allow create: if isSignedIn() && isValidGoal(incoming());
      allow update, delete: if isSignedIn() && (isOwner(existing().userId) || isAnyManager());
    }

    // Dealer Requests Collection
    match /dealerRequests/{requestId} {
      // Users can see their own requests (including via query), admins can see all
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAnyAdmin());
      
      // Any signed in user can create a request for themselves
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid && 
                      incoming().status == 'pending_review';
      
      // Only admins can update the status (approve/reject)
      allow update: if isAnyAdmin();
      allow delete: if isAnyAdmin();
    }

    // Dealer Join Codes Collection
    match /dealerJoinCodes/{codeId} {
      // Users can get codes for redemption, managers can list/manage
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isAnyManager();
      
      // Managers can create codes for their own org
      allow create: if isSignedIn() && isAnyManager() && isOrgMember(incoming().organizationId);
      
      // Managers can update codes, OR any user can update when redeeming (increment count, update status)
      allow update: if isSignedIn() && (
        (isAnyManager() && isOrgMember(resource.data.organizationId)) ||
        isValidJoinCodeRedemption(existing(), incoming())
      );
      
      allow delete: if isSignedIn() && isAnyManager() && isOrgMember(resource.data.organizationId);
    }

    // Guest Sheets — private to the owning user only
    match /guestSheets/{sheetId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Sales Menus — private to the owning user only
    match /salesMenus/{menuId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}

