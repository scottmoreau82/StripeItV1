rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function getUserSafe(userId) {
      let path = /databases/$(database)/documents/users/$(userId);
      return exists(path) ? get(path).data : null;
    }
    
    function isOrgMember(orgId) {
      let user = getUserSafe(request.auth.uid);
      return isSignedIn() && user != null && user.orgId == orgId;
    }
    
    function getRole() {
      let user = getUserSafe(request.auth.uid);
      return user != null ? user.role : 'none';
    }
    
    function isAnyManager() {
      return getRole() in ['manager', 'gm', 'admin'];
    }
    
    function isManager(orgId) {
      return isOrgMember(orgId) && isAnyManager();
    }

    function isAnyAdmin() {
      return getRole() in ['gm', 'admin'];
    }

    // --- VALIDATION HELPERS ---

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['sales', 'manager', 'gm', 'admin'] &&
             data.subscriptionTier in ['free', 'basic', 'pro', 'organization'];
    }

    function isValidDeal(data) {
      return data.customerName is string && 
             data.userId is string && 
             data.orgId is string &&
             data.status in ['working', 'pending', 'Submitted', 'Finalized', 'Cancelled', 'Draft'];
    }

    function isValidNote(data) {
      return data.text is string && 
             data.userId == request.auth.uid &&
             data.orgId is string;
    }

    function isValidGoal(data) {
      return data.userId == request.auth.uid &&
             data.unitGoal is number && 
             data.month is string;
    }

    // --- COLLECTION RULES ---

    // User Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || (isSignedIn() && isAnyManager() && isOrgMember(getUserSafe(userId).orgId));
      allow list: if false; 
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'dashboardPreference', 'updatedAt', 'preferences', 'dealershipId', 'orgId'])
      ) || (
        isAnyManager() && isOrgMember(existing().orgId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['role', 'dealershipId', 'updatedAt'])
      );
      
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Organization Collection
    match /organizations/{orgId} {
      allow get: if isSignedIn() && (isOrgMember(orgId) || (resource != null && resource.data.ownerId == request.auth.uid));
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (isAnyAdmin() || (resource != null && resource.data.ownerId == request.auth.uid));

      match /activity/{eventId} {
        allow get, list: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
      }

      match /deals/{dealId} {
        allow get, list: if isOrgMember(orgId) && (isAnyManager() || (resource != null && resource.data.userId == request.auth.uid));
        allow create: if isOrgMember(orgId) && isValidDeal(incoming());
        allow update: if isOrgMember(orgId) && (isAnyManager() || (resource != null && resource.data.userId == request.auth.uid));
        allow delete: if isOrgMember(orgId) && isAnyManager();
      }

      match /dealerships/{dsId} {
        allow read: if isOrgMember(orgId);
        allow write: if isAnyAdmin();
      }

      match /notes/{noteId} {
        allow get, list: if isOrgMember(orgId) && (resource == null || resource.data.userId == request.auth.uid);
        allow create: if isOrgMember(orgId) && isValidNote(incoming());
        allow update, delete: if isOrgMember(orgId) && existing().userId == request.auth.uid;
      }

      match /competitions/{compId} {
        allow get, list: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && isAnyManager();
      }

      match /users/{userId}/payPlans/{planId} {
        allow read, write: if isOrgMember(orgId) && isOwner(userId);
      }
    }

    match /goals/{goalId} {
      allow get, list: if isSignedIn() && (resource == null || isOwner(resource.data.userId) || isOrgMember(resource.data.orgId));
      allow create: if isSignedIn() && isValidGoal(incoming());
      allow update, delete: if isSignedIn() && (isOwner(existing().userId) || isAnyManager());
    }
  }
}
